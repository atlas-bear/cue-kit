# cue-kit configuration — copy to ~/.config/cue-kit/.env (or .env in CWD)
# At minimum, set one Whisper provider key if your videos lack native captions.

# Groq (preferred — cheaper, faster). Get a key at https://console.groq.com/keys
GROQ_API_KEY=

# OpenAI (fallback). Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Default output directory (overridden by --out-dir).
# CUE_KIT_OUT_DIR=~/cue-kit-output
